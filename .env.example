# Shopify Development Store — connection secrets
SHOPIFY_STORE_URL=https://your-dev-store.myshopify.com
SHOPIFY_STORE_PASSWORD=           # Password-protected store access password (if applicable)

# Vision LLM — local model served via LM Studio (OpenAI-compatible endpoint)
VISION_BASE_URL=http://localhost:1234/v1
VISION_MODEL=your-model-name          # Exact model identifier as shown in LM Studio
VISION_API_KEY=lm-studio              # LM Studio ignores this; the OpenAI client library requires a non-empty value

# Test scenario data lives in config/test-data.js — not here.
